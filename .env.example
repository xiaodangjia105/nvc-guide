# ================================
# 必需配置 - 请替换为您的实际密钥
# ================================

# 阿里云百炼 AI (DashScope) - LLM + ASR + TTS 服务
AI_BAILIAN_API_KEY=your_dashscope_api_key_here

# ================================
# 文字服务配置
# ================================

# LM Studio 本地 Provider（可选）
# PROVIDER_LMSTUDIO_API_KEY=lm-studio

# Moonshot AI / Kimi (https://platform.moonshot.cn/)
PROVIDER_KIMI_API_KEY=
PROVIDER_KIMI_MODEL=kimi-k2.6

# DeepSeek (https://platform.deepseek.com/)
PROVIDER_DEEPSEEK_API_KEY=
PROVIDER_DEEPSEEK_MODEL=deepseek-v4-flash

# 智谱 AI / GLM (https://open.bigmodel.cn/)
PROVIDER_GLM_API_KEY=
PROVIDER_GLM_MODEL=glm-5

# 自定义 OpenAI 兼容 Provider 示例:
# 添加后需在 application.yml 的 app.ai.providers 中配置对应的 base-url 和 model
# PROVIDER_MYPROVIDER_API_KEY=your_api_key_here

# ================================
# 可选配置 - 与根目录 docker-compose.yml 对齐（本地 bootRun 连 compose 起的依赖时勿改）
# ================================

# PostgreSQL（compose 默认：库 interview_guide / 用户 postgres / 密码 password / 映射端口 5432）
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=interview_guide
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Redis（compose 映射 6379）
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO / S3 兼容存储（compose：MINIO_ROOT_USER/PASSWORD=minioadmin，API 映射 9000）
APP_STORAGE_ENDPOINT=http://localhost:9000
APP_STORAGE_ACCESS_KEY=minioadmin
APP_STORAGE_SECRET_KEY=minioadmin
APP_STORAGE_BUCKET=interview-guide

# AI 模型配置（默认: qwen3.5-flash）
AI_MODEL=qwen3.5-flash

# 语音面试（可选）：多段 STT 合并后再触发面试官；ASR 句间静音阈值（越大越不易句中切开）
# APP_VOICE_USER_UTTERANCE_DEBOUNCE_MS=1600
# APP_VOICE_ASR_SILENCE_MS=1000
